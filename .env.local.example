# Copy this file to .env.local and fill in real values from your Supabase project.
# Settings → API in the Supabase dashboard.

NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...

# Settings → Database → Connection string → "Transaction" pooler (port 6543)
# Used by Drizzle migrations and any direct DB queries.
DATABASE_URL=postgresql://postgres.YOUR-PROJECT-REF:YOUR-DB-PASSWORD@aws-0-us-east-1.pooler.supabase.com:6543/postgres

# Optional: site URL used for magic-link redirects.
# Leave as-is for local dev; Vercel will inject the real one in production.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
